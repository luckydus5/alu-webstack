global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    maxconn 2048
    tune.ssl.default-dh-param 2048

defaults
    log global
    mode http
    option httplog
    option dontlognull
    retries 3
    option redispatch
    timeout connect 5000
    timeout client 30000
    timeout server 30000

frontend www-http
    bind *:80
    http-request redirect scheme https code 301

frontend www-https
    bind *:443 ssl crt /etc/haproxy/certs/www.rwandahealthlink.tech.pem
    http-request set-header X-Forwarded-Proto https
    default_backend web-backend

backend web-backend
    balance roundrobin
    server web-01 13.218.57.12:80 check
    server web-02 44.202.228.82:80 check
